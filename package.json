{
  "name": "agent-fleet",
  "version": "0.1.0",
  "description": "Claude Code + Codex dual-model collaboration via MCP and tmux",
  "type": "module",
  "bin": {
    "agent-fleet": "./bin/agent-fleet.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
